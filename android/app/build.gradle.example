# StealthChat Android Configuration
# Anti-DPI: Uses system TLS stack for browser-like fingerprint

android {
    compileSdk 34

    defaultConfig {
        applicationId "com.stealthchat.app"
        minSdk 24
        targetSdk 34
        versionCode 1
        versionName "1.0"

        # Enable TLS 1.3 by default
        multiDexEnabled true
    }

    buildTypes {
        release {
            signingConfig signingConfigs.debug
            minifyEnabled false
            proguardFiles getDefaultProguardFile('proguard-android-optimize.txt'), 'proguard-rules.pro'
        }
    }
}

// Network security config for TLS
// Place in res/xml/network_security_config.xml for custom certificates
